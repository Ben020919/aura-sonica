# 複製呢個做 .env 再改。本機開發預設用 SQLite（唔使裝 Postgres）。
# Render 部署時，DATABASE_URL 會由 Render Postgres 自動注入。

DATABASE_URL=sqlite:///./aura.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5178,http://localhost:5173,https://aura-sonica.onrender.com
# 呢啲 email 註冊時會自動變成管理員（可以入後台）
ADMIN_EMAILS=VENUSLEUNG412@GMAIL.COM
